---
import Layout from '../layouts/Layout.astro';
---
<Layout titulo="QR Payment — Demo">
  <div class="min-h-screen bg-background flex flex-col items-center justify-center px-6">
    <div class="w-full max-w-sm text-center">
      <div class="w-20 h-20 bg-brand rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="7" height="7"/>
          <rect x="14" y="3" width="7" height="7"/>
          <rect x="3" y="14" width="7" height="7"/>
          <path d="M14 14h.01M14 17h3M17 14v3M20 17v.01M20 14v.01"/>
        </svg>
      </div>

      <h1 class="text-3xl font-bold text-gray-900 mb-2">QR Payment</h1>
      <p class="text-gray-400 text-sm mb-10">Scan the QR code at your table to get started</p>

      <div class="bg-white rounded-2xl shadow-sm p-5 mb-6 text-left">
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-3">Quick demo</p>
        <div class="space-y-2">
          <a href="/table/26" class="flex items-center justify-between py-3 border-b border-gray-100">
            <span class="text-sm font-medium text-gray-900">Table N°26 — Landing</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </a>
          <a href="/bill/26" class="flex items-center justify-between py-3 border-b border-gray-100">
            <span class="text-sm font-medium text-gray-900">Table N°26 — Bill</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </a>
          <a href="/tip/26" class="flex items-center justify-between py-3">
            <span class="text-sm font-medium text-gray-900">Table N°26 — Tip</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </a>
        </div>
      </div>

      <a
        href="/table/26"
        class="block w-full bg-brand text-white py-4 rounded-2xl font-semibold text-base"
      >
        Start full demo →
      </a>
    </div>
  </div>
</Layout>
